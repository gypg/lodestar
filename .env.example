# =============================================================================
# Lodestar 部署环境变量模板
# 用法：cp .env.example .env，填好下面的值，再 docker compose pull && docker compose up -d
# ⚠️ .env 不入 git（已在 .gitignore）；切勿提交真实密钥。.env.example 是模板，可提交。
# =============================================================================

# ---- 鉴权 / 加密（一次性生成，妥善备份，勿改动）----

# JWT 签名密钥：留空则每次重启生成临时密钥→重启即掉登录。务必设。
#   生成：openssl rand -hex 32
LODESTAR_AUTH_JWT_SECRET=

# 敏感凭据加密密钥：加密存储的渠道 API key 等密文。留空则回落到 JWT secret。
# ⚠️ 一旦有数据后不可更改（改了无法解密旧密文）——架构搭建时一次性生成并备份。
#   生成：openssl rand -hex 32
LODESTAR_SECURITY_ENCRYPTION_KEY=

# ---- PostgreSQL（复用服务器 172.16.0.87:5432）----
# 为 Lodestar 新建独立库 `lodestar` + 独立角色 `lodestar`，用新鲜密码
# （不要用暴露过的 postgres 超管密码 GGGZERO690582504.）。
# 首启自动迁移建表（GORM AutoMigrate + 版本化迁移），无需手动建表。
LODESTAR_DATABASE_TYPE=postgres
LODESTAR_DATABASE_PATH=host=172.16.0.87 port=5432 user=lodestar password=CHANGE_ME dbname=lodestar sslmode=disable

# 可选：relay 日志独立库（数据量大时启用，可秒级清理/卸载日志而不动主库）
# LODESTAR_DATABASE_LOG_TYPE=postgres
# LODESTAR_DATABASE_LOG_PATH=host=172.16.0.87 port=5432 user=lodestar password=CHANGE_ME dbname=lodestar_log sslmode=disable

# ---- Redis（复用服务器 172.16.0.87:6379）----
# 用独立 db 索引与旧 newapi 隔离（旧用 /1，Lodestar 用 /2）。
# 留空 LODESTAR_REDIS_HOST 则跳过 Redis、回落内存缓存（单实例自用可跑；多实例/商业模式建议启用）。
LODESTAR_REDIS_HOST=172.16.0.87
LODESTAR_REDIS_PORT=6379
LODESTAR_REDIS_PASSWORD=
LODESTAR_REDIS_DB=2
