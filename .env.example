# =============================================================================
# Lodestar 部署环境变量模板
# 用法：cp .env.example .env，填好下面的值，再 docker compose pull && docker compose up -d
# ⚠️ .env 不入 git（已在 .gitignore）；切勿提交真实密钥。.env.example 是模板，可提交。
# =============================================================================

# ---- 鉴权 / 加密（一次性生成，妥善备份，勿改动）----

# JWT 签名密钥：留空则每次重启生成临时密钥→重启即掉登录。务必设。
#   生成：openssl rand -hex 32
LODESTAR_AUTH_JWT_SECRET=

# 敏感凭据加密密钥：加密存储的渠道 API key 等密文。留空则回落到 JWT secret。
# ⚠️ 一旦有数据后不可更改（改了无法解密旧密文）——架构搭建时一次性生成并备份。
#   生成：openssl rand -hex 32
LODESTAR_SECURITY_ENCRYPTION_KEY=

# ---- PostgreSQL ----
# Create a dedicated database `lodestar` and role `lodestar` with a STRONG password.
# ⚠️ Set a strong password, do NOT use production credentials or reuse passwords from other services.
# Auto-migrates on first start (GORM AutoMigrate + versioned migrations), no manual DDL needed.
LODESTAR_DATABASE_TYPE=postgres
LODESTAR_DATABASE_PATH=host=YOUR_DB_HOST port=5432 user=lodestar password=CHANGE_ME dbname=lodestar sslmode=disable

# 可选：relay 日志独立库（数据量大时启用，可秒级清理/卸载日志而不动主库）
# LODESTAR_DATABASE_LOG_TYPE=postgres
# LODESTAR_DATABASE_LOG_PATH=host=YOUR_DB_HOST port=5432 user=lodestar password=CHANGE_ME dbname=lodestar_log sslmode=disable

# ---- Redis ----
# Use a dedicated DB index to isolate from other apps (e.g. old newapi uses /1, Lodestar uses /2).
# Leave LODESTAR_REDIS_HOST empty to skip Redis and fall back to in-memory cache
# (fine for single-instance; multi-instance or production should enable Redis).
LODESTAR_REDIS_HOST=YOUR_REDIS_HOST
LODESTAR_REDIS_PORT=6379
LODESTAR_REDIS_PASSWORD=
LODESTAR_REDIS_DB=2
